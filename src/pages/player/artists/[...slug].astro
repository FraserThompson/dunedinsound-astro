---
import { loadAndFormatCollection } from 'src/util/collection.ts'
import ArtistPlayer from 'src/layouts/collection/ArtistPlayer.astro'
import { artistPlayerThreshold } from 'src/util/constants'

export async function getStaticPaths() {
	const entries = await loadAndFormatCollection('artist')
	return Promise.all(
		entries
			.filter((entry) => entry.extra.gigCount > artistPlayerThreshold)
			.map(async (entry) => {
				return {
					params: { slug: entry.extra.slug },
					props: {
						entry
					}
				}
			})
	)
}

const { entry } = Astro.props
---

<ArtistPlayer entry={entry} />
