---
import instaIcon from '../assets/instagram-icon.png'
import youtubeIcon from '../assets/youtube-icon.png'
import RssIcon from '~icons/iconoir/rss-feed-tag-solid'
import { footerContent, footerWrapper } from './SiteFooter.css'

interface Props {
	className?: string
	style?: Partial<CSSStyleDeclaration>
	hasSidebar?: boolean
}

const { hasSidebar, className, style } = Astro.props
---

<div class:list={[footerWrapper, className]} style={style}>
	<div class:list={[footerContent, { hasSidebar: hasSidebar }]}>
		<p>
			A permanent and non-commercial media archive for gigs in Ōtepoti since 2014.<br />
			<a href="/page/info/" title="Info">More Info</a> |
			<a href="/page/subscribe/" title="Subscribe">Subscribe</a> |
			<a href="https://ko-fi.com/dunedinsound/" target="_blank" rel="noopener" title="Donate">Donate</a>
		</p>
		<div id="footer-social-icons">
			<a title="Instagram" target="_blank" rel="noopener" href="https://instagram.com/dunedinsound/">
				<img src={instaIcon.src} width="50" height="50" alt="Instagram" />
			</a>
			<a title="YouTube" target="_blank" rel="noopener" href="https://www.youtube.com/@dunedinsound">
				<img src={youtubeIcon.src} width="50" height="50" alt="YouTube" />
			</a>
			<a title="Subscribe to RSS feed" href="/rss.xml">
				<RssIcon width="50px" height="50px" aria-label="Subscribe to RSS feed" />
			</a>
		</div>
	</div>
</div>
