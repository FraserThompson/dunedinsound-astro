---
/**
 * Menu of all gigs on the website, sorted by date and month.
 *
 * It responds to shuffle events to filter its items.
 *
 * Props:
 *  selected (optional): it will show the artists under that gig.
 */
import { type SortedGigs } from 'src/util/collection.ts'
import DropdownMenu from '../DropdownMenu'
import { theme } from '../../Theme.css'
import { getGigYearDropdownItems } from 'src/util/helpers'

interface Props {
	sortedGigs: SortedGigs
}

const { sortedGigs } = Astro.props
---

<DropdownMenu
	list={getGigYearDropdownItems(sortedGigs)}
	direction="down"
	backgroundColor="white"
	textColor="black"
	width="100%"
	heightMobile={theme.dimensions.headerHeightMobile}
	top={'0px'}
	client:load
/>
