---
/**
 * Encapsulates filter, sort, and search functionality for elements on the page.
 *
 * To use give the items you want to be filterable the class 'filter-item'.
 * If you want the items to also be sortable (eg. reorderable) their container
 * must have the class 'filter-container'.
 *
 * Other components can listen for the 'shuffle:filter' event to respond when
 * this component filters stuff.
 *
 * Props:
 * - search (optional): Supply a placeholder string to enable searching of the text inside elements.
 * - sort (optional): Array of Sorters
 * - filter (optional): Array of Filters
 * - className (optional): Class to add to the wrapper
 * - openSearchWithSidebar(optional): If true, search will be hidden and only opened with the sidebar on mobile.
 * - openSortWithSidebar(optional): If true, sort will be hidden and only opened with the sidebar on mobile.
 * - openFilterWithSidebar(optional): If true, filter will be hidden and only opened with the sidebar on mobile.
 * - inPopover(optional): If true, sorts and filters will be put in a popover in all device sizes.
 * sidebar is opened. This will also hide filters/sorters inside a button which pops a Popover.
 */

import { shuffleFilter, modalFiltersWrapper, dropdownButton } from './ShuffleFilters.css'
import { searchboxWrapper } from './SearchBox.css'
import SortIcon from '~icons/iconoir/sort'
import SearchIcon from '~icons/iconoir/search'
import FilterIcon from '~icons/iconoir/filter'
import GlobeIcon from '~icons/iconoir/globe'
import Popover from './Popover.astro'

export interface Sorter {
	value: string
	order: string
	title: string
}

export interface Filter {
	value?: string
	values?: string[][]
	title: string
	checkedTitle?: string
	icon?: string
	type: 'select' | 'checkbox'
}

interface Props {
	search?: string
	sort?: Sorter[]
	filter?: Filter[]
	className?: string
	style?: Partial<CSSStyleDeclaration>
	openSearchWithSidebar?: boolean
	openSortWithSidebar?: boolean
	openFilterWithSidebar?: boolean
	inPopover?: boolean
}

const {
	openSearchWithSidebar,
	openSortWithSidebar,
	openFilterWithSidebar,
	inPopover,
	search,
	sort,
	filter,
	className = '',
	style
} = Astro.props
---

<shuffle-filters class:list={[shuffleFilter, className]} style={style}>
	{/* SEARCH */}
	{
		search && (
			<label
				class={`${searchboxWrapper} fixedBottomMobile flex ${openSearchWithSidebar ? 'openWithSidebar bottom' : ''}`}
			>
				<SearchIcon class="hideMobile" />
				<input type="search" name="search" placeholder={search} />
			</label>
		)
	}

	{/* INLINE ELEMENTS (Hidden on mobile if assigned to sidebar) */}
	{
		sort && !inPopover && (
			<label class={openSortWithSidebar ? 'hideMobile' : undefined}>
				<SortIcon aria-label="Sort by" />
				<select data-sort>
					{sort.map((s) => (
						<option value={s.value} data-order={s.order}>
							{s.title}
						</option>
					))}
				</select>
			</label>
		)
	}

	{
		!inPopover &&
			filter?.map((f) =>
				f.type !== 'select' ? (
					<label class={openFilterWithSidebar ? 'hideMobile' : undefined}>
						<input name={f.value} value={f.value} type={f.type} />
						{!f.icon ? f.title : f.icon === 'globe' && <GlobeIcon />}
					</label>
				) : (
					<label class:list={['flex', { hideMobile: openFilterWithSidebar }]}>
						{!f.icon ? f.title : f.icon === 'globe' && <GlobeIcon />}
						<select name={f.title} data-filter>
							<option value="">All</option>
							{f.values?.map(([title, value]) => (
								<option value={value}>{title}</option>
							))}
						</select>
					</label>
				)
			)
	}

	{/* MODAL / POPOVER ELEMENTS (Hidden on desktop, only renders if sidebar features are active) */}
	{
		(openSortWithSidebar || openFilterWithSidebar) && (sort || filter) && (
			<Popover className={`${dropdownButton} openWithSidebar top ${!inPopover ? 'showMobile' : ''}`}>
				<FilterIcon slot="button" />
				<div slot="content" class={`${modalFiltersWrapper}`}>
					{openSortWithSidebar && sort && (
						<label>
							<SortIcon aria-label="Sort by" />
							<select data-sort>
								{sort.map((s) => (
									<option value={s.value} data-order={s.order}>
										{s.title}
									</option>
								))}
							</select>
						</label>
					)}

					{openFilterWithSidebar &&
						filter?.map((f) =>
							f.type !== 'select' ? (
								<label>
									<input name={f.value} value={f.value} type={f.type} />
									{!f.icon ? f.title : f.icon === 'globe' && <GlobeIcon />}
								</label>
							) : (
								<label class="flex">
									{!f.icon ? f.title : f.icon === 'globe' && <GlobeIcon />}
									<select name={f.title} data-filter>
										<option value="">All</option>
										{f.values?.map(([title, value]) => (
											<option value={value}>{title}</option>
										))}
									</select>
								</label>
							)
						)}
				</div>
			</Popover>
		)
	}
</shuffle-filters>

<script>
	import { filterEventName, type FilterEventDetails } from 'src/util/events'
	import { stringNormalize } from 'src/util/names'

	class ShuffleFilters extends HTMLElement {
		htmlElements: HTMLElement[]
		filteredElements: HTMLElement[]
		sidebar: HTMLElement | null
		container: HTMLElement | null

		searchValue: string
		sortValue: string
		sortOrder: number
		filters: string[]
		selectFilters: Record<string, string>

		searchElement: HTMLInputElement | null
		selectFilterElements: NodeListOf<HTMLSelectElement> | null
		checkboxFilterElements: NodeListOf<HTMLInputElement> | null
		sortElements: NodeListOf<HTMLSelectElement> | null

		constructor() {
			super()

			const itemSelector = '.filter-item'
			const containerSelector = '.filter-container'

			this.htmlElements = Array.from(document.querySelectorAll(itemSelector))
			this.container = document.querySelector(containerSelector)
			this.sidebar = document.querySelector('#sidebar-menu')

			this.filters = []
			this.filteredElements = []
			this.selectFilters = {}

			this.searchValue = ''
			this.sortValue = ''
			this.sortOrder = 1

			this.searchElement = this.querySelector('input[type=search]')
			this.selectFilterElements = this.querySelectorAll('select[data-filter]')
			this.checkboxFilterElements = this.querySelectorAll('input[type=checkbox]')
			this.sortElements = this.querySelectorAll('select[data-sort]')
		}

		filterItem = (item: HTMLElement) => {
			const lowerSearch = stringNormalize(this.searchValue)
			const elementSearchableText = `${item.innerText}${item.dataset.searchable || ''}`
			const searchResult = stringNormalize(elementSearchableText).includes(lowerSearch)
			const itemCategories = item.dataset.category?.split(',')
			const combinedFilters = [...this.filters, ...Object.values(this.selectFilters)]

			const filterResult =
				combinedFilters.length > 0
					? combinedFilters.every((filter) => itemCategories && itemCategories.includes(filter))
					: true

			const visible = searchResult && filterResult

			if (visible) {
				item.classList.remove('hidden')
			} else {
				item.classList.add('hidden')
			}

			return visible
		}

		toggleFilter = (value: string) => {
			if (this.filters.includes(value)) {
				this.filters = this.filters.filter((currentFilter) => currentFilter !== value)
			} else {
				this.filters = [...this.filters, value]
			}
		}

		selectFilter = (name: string, value: string) => {
			const newFilters = { ...this.selectFilters }
			if (!value) {
				delete newFilters[name]
			} else {
				newFilters[name] = value
			}
			this.selectFilters = newFilters
		}

		filterItems = () => {
			const filtered = this.htmlElements.filter((item) => this.filterItem(item))

			if (this.sortValue) {
				this.filteredElements = filtered.sort((a, b) => {
					const sortA = a.dataset[this.sortValue] || ''
					const sortB = b.dataset[this.sortValue] || ''
					const aNumber = parseInt(sortA)
					const bNumber = parseInt(sortB)

					if (!isNaN(aNumber) && !isNaN(bNumber)) {
						return (aNumber - bNumber) * this.sortOrder
					} else {
						return sortA.localeCompare(sortB) * this.sortOrder
					}
				})

				if (this.container) {
					this.htmlElements.forEach((item) => {
						if (item.parentElement === this.container) {
							this.container?.removeChild(item)
						}
					})
					this.filteredElements.forEach((item) => {
						this.container?.appendChild(item)
					})
				}
			} else {
				this.filteredElements = filtered
			}

			this.sidebar?.scrollTo(0, 0)
			this.onChange()
		}

		onChange = () => {
			const detail: FilterEventDetails = {
				items: this.htmlElements,
				searchValue: this.searchValue,
				filteredItems: this.filteredElements
			}
			const event = new CustomEvent(filterEventName, { detail })
			window.dispatchEvent(event)
		}

		onSearch = (e: Event) => {
			const target = e.currentTarget as HTMLInputElement
			this.searchValue = target.value
			this.filterItems()
		}

		onSelectFilter = (e: Event) => {
			const target = e.target as HTMLSelectElement
			this.selectFilter(target.name, target.value)
			this.filterItems()
		}

		onCheckboxFilter = (e: Event) => {
			const target = e.currentTarget as HTMLInputElement
			this.toggleFilter(target.value)
			this.filterItems()
		}

		onSort = (e: Event) => {
			const target = e.target as HTMLSelectElement
			const selectedOption = target.options[target.selectedIndex]
			this.sortValue = target.value
			this.sortOrder = selectedOption.dataset.order === 'asc' ? 1 : -1
			this.filterItems()
		}

		connectedCallback() {
			this.searchElement?.addEventListener('input', this.onSearch)
			this.selectFilterElements?.forEach((el) => el.addEventListener('change', this.onSelectFilter))
			this.checkboxFilterElements?.forEach((el) => el.addEventListener('input', this.onCheckboxFilter))
			this.sortElements?.forEach((el) => el.addEventListener('change', this.onSort))
		}

		disconnectedCallback() {
			this.searchElement?.removeEventListener('input', this.onSearch)
			this.selectFilterElements?.forEach((el) => el.removeEventListener('change', this.onSelectFilter))
			this.checkboxFilterElements?.forEach((el) => el.removeEventListener('input', this.onCheckboxFilter))
			this.sortElements?.forEach((el) => el.removeEventListener('change', this.onSort))
		}
	}

	customElements.define('shuffle-filters', ShuffleFilters)
</script>
