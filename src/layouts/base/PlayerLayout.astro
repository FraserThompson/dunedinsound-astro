---
/**
 * A layout with a player for playing one artists audio.
 *
 * Props:
 *  - audioFromGigs: Array of PlayerAudio elements to put in the playlist
 *  - gigsFromEntry: The Entry which the gigs are from (optional)
 */
import { loadAndFormatCollection, type PlayerAudio, type ProcessedEntry } from '@src/util/collection'
import SidebarPlayer from '@src/components/gig/SidebarPlayer'
import ImageGallery from '@src/components/ImageGallery.astro'
import BaseLayout from '../base/BaseLayout.astro'
import { artistPlayerThreshold, seriesVenuePlayerThreshold } from '@src/util/constants'
import DropdownMenu from '@src/components/DropdownMenu.astro'
import { fileButton, gigMetaWrapper } from '@src/layouts/base/PlayerLayout.css'
import type { MenuLink } from '@src/components/Menu.astro'

interface Props {
	audioFromGigs?: PlayerAudio[]
	gigsFromEntry?: ProcessedEntry<'artist'> | ProcessedEntry<'venue'> | ProcessedEntry<'series'>
}

const { gigsFromEntry, audioFromGigs } = Astro.props

const artists = await loadAndFormatCollection('artist', (entry) => entry.extra.gigCount > artistPlayerThreshold)
const venues = await loadAndFormatCollection('venue', (entry) => entry.extra.gigCount > seriesVenuePlayerThreshold)
const series = await loadAndFormatCollection('series', (entry) => entry.extra.gigCount > seriesVenuePlayerThreshold)

const artistList: MenuLink[] = artists.map((entry) => ({
	title: entry.entry.data.title,
	subtitle: entry.extra.gigCount,
	href: `/player/artist/${entry.entry.id}`
}))
const venuesList: MenuLink[] = venues.map((entry) => ({
	title: entry.entry.data.title,
	subtitle: entry.extra.gigCount,
	href: `/player/venue/${entry.entry.id}`
}))
const seriesList: MenuLink[] = series.map((entry) => ({
	title: entry.entry.data.title,
	subtitle: entry.extra.gigCount,
	href: `/player/series/${entry.entry.id}`
}))
---

<BaseLayout
	hideFooter={true}
	poo={{
		title: gigsFromEntry ? `${gigsFromEntry.entry.data.title} Player` : 'Player',
		description: gigsFromEntry ? `Play audio bootlages from ${gigsFromEntry.entry.data.title}.` : 'Audio player'
	}}
>
	<SidebarPlayer
		title={`${gigsFromEntry ? gigsFromEntry.entry.id : ''} PLAYER`}
		playerAudio={audioFromGigs}
		client:load
	>
		<DropdownMenu
			slot="menu"
			list={[
				{ title: 'Load an artist', submenu: artistList },
				{ title: 'Load a venue', submenu: venuesList },
				{ title: 'Load a series', submenu: seriesList },
				{ title: 'Load all', href: '/player/gig' }
			]}
			buttonHeight={'20px'}
			direction="down"
			width="200px"
			buttonPosition="left"
			backgroundColor="#353551"
		>
			<div class={fileButton} slot="button">File</div>
		</DropdownMenu>
		<div
			id="gig-meta"
			class={gigMetaWrapper}
			data-artist={gigsFromEntry && gigsFromEntry.entry.collection === 'artist' ? gigsFromEntry.entry.id : 'index'}
			data-gig={''}
		>
		</div>
		<ImageGallery thumbnailWidthDesktop="250px" />
	</SidebarPlayer>
</BaseLayout>

<script>
	import {
		imageGalleryUpdateEventName,
		playerTrackChange,
		type ImageGalleryUpdateEventDetails,
		type PlayerTrackChangeEventDetails
	} from '@src/util/events'

	import { getEntryPath, type ArtistGigResponse } from '@src/util/helpers'
	import { formattedDate } from '@src/util/names'

	const init = () => {
		const metaContainer: HTMLElement | null = document.querySelector('#gig-meta')

		/**
		 * When the track changes, grab data about the gig.
		 */
		window.addEventListener(playerTrackChange, async (e: any) => {
			const detail: PlayerTrackChangeEventDetails = e.detail

			const artistId = detail.track.dataAttributes?.['data-artist']
			const gigId = detail.track.dataAttributes?.['data-gig']

			if (!gigId) return

			const req = await fetch(`/data/gigs/${gigId}/${artistId}.json`)

			if (req.ok) {
				const json: ArtistGigResponse = await req.json()

				if (json.images) {
					// Give images to the image gallery
					const detail: ImageGalleryUpdateEventDetails = {
						images: json.images
					}
					const event = new CustomEvent(imageGalleryUpdateEventName, {
						detail
					})
					window.dispatchEvent(event)
				}

				if (!metaContainer) return

				const gig = json.data

				const texts: Node[] = []

				const text = document.createElement('p')
				text.setAttribute('style', 'padding:0;margin:0;')
				text.innerHTML = `title: ${gig.data.title} <a href="${getEntryPath(gig.data.title, 'gig')}">[gig page]</a>`
				texts.push(text)

				// Update metadata section
				const allowedFields = ['date', 'artists', 'description']
				const selectedArtist = detail.track.dataAttributes?.['data-artist']
				Object.entries(gig.data).forEach(([key, value]) => {
					const text = document.createElement('p')
					text.setAttribute('style', 'padding:0;margin:0;')

					if (!allowedFields.includes(key)) {
						return
					} else if (typeof value === 'string' && key === 'date') {
						text.innerHTML = `${key}: ${formattedDate(new Date(value))}`
					} else if (typeof value === 'string') {
						text.innerHTML = `${key}: ${value}`
					} else if (Array.isArray(value)) {
						const valueTexts = value.map((thing) =>
							thing.id.id !== selectedArtist ? `<span>${thing.id.id}</span>` : `<strong class='selectedArtist'>${thing.id.id}</strong>`
						)
						text.innerHTML = `${key}: ${valueTexts.join(', ')}`
					} else if (typeof value === 'object' && 'id' in value) {
						text.innerHTML = `${key}: ${value.id}`
					}
					texts.push(text)
				})

				metaContainer.dataset.gig = gigId
				metaContainer.replaceChildren(...texts)
			}
		})
	}

	document.addEventListener('astro:page-load', init)
	document.addEventListener('astro:after-swap', init)
</script>
